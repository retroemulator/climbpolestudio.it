# ──────────────────────────────────────────────────────────────
# Climb Pole Studio — variabili d'ambiente
# Copia in `.env.local` e compila quando arrivi alle fasi relative.
# NESSUNA di queste è necessaria per le Fasi 1–3 (UI/layout statici).
# ──────────────────────────────────────────────────────────────

# Generale
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity — Fase 4 (CMS contenuti). Project ID e dataset sono pubblici.
NEXT_PUBLIC_SANITY_PROJECT_ID=shudbapr
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Token "Editor": SOLO server-side (seed/scrittura). Mai esporre al client.
SANITY_API_TOKEN=
# Secret del webhook di revalidation (Studio → online in pochi secondi senza redeploy).
# Stessa stringa qui (Vercel) e nel webhook su sanity.io/manage. Vedi app/api/revalidate/route.ts
SANITY_REVALIDATE_SECRET=

# Supabase — Fase 9/10 (auth magic link + prenotazioni). URL/anon sono pubblici.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOLO server (seed sessioni/cron). MAI esporre al client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — Fase 14 (email form contatti). Dominio mittente da verificare in Resend.
RESEND_API_KEY=

# Cron Vercel (protegge /api/cron/generate-sessions). Stringa casuale a piacere.
CRON_SECRET=
